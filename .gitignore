# -------------------------------------------------------------------------
# StackMoney - Official .gitignore (Public Repo Optimized)
# -------------------------------------------------------------------------

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDEs and Editors (Strict JetBrains / Android Studio / VS Code Rules)
.idea/workspace.xml
.idea/tasks.xml
.idea/modules.xml
.idea/dictionaries/
.idea/libraries/
.idea/caches/
.idea/compiler.xml
.idea/jarRepositories.xml
*.iws
*.iml
.vscode/

# Flutter / Dart / Pub
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
.pub-preload-cache/
.pub/
build/
lib/generated_plugin_registrant.dart

# FVM (Flutter Version Management)
.fvm/flutter_sdk
!.fvm/fvm_config.json

# Web tools cache
.webpack/
.sass-cache/

# -------------------------------------------------------------------------
# Android Specific
# -------------------------------------------------------------------------
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/key.properties
**/android/**/GeneratedPluginRegistrant.java

# Android Keystores and Tokens (Security Critical)
*.jks
*.keystore
*.p12
*.pem

# -------------------------------------------------------------------------
# iOS Specific
# -------------------------------------------------------------------------
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/.generated/

# CocoaPods
**/ios/Pods/
**/ios/.symlinks/
**/ios/DerivedData/
**/ios/**/xcuserdata/

# -------------------------------------------------------------------------
# Firebase & Environment Secrets (CRITICAL FOR PUBLIC REPOS)
# -------------------------------------------------------------------------

# Firebase & Environment Secrets (CRITICAL FOR PUBLIC REPOS)
**/android/app/google-services.json
**/ios/Runner/GoogleService-Info.plist

# Add this line to protect your FlutterFire auto-generated options
lib/firebase_options.dart

# Local environment variables
.env
.env.*
!.env.example

# Firebase CLI cache & logs
.firebase/
firebase-debug.log*
.runtimeconfig.json
.emulator-ui/
firebase-export-*/

# Cloud Functions
functions/node_modules/
functions/lib/
functions/npm-debug.log*