# -------------------------------------------------------------------------
# StackMoney - Official .gitignore (Public Repo Optimized)
# -------------------------------------------------------------------------

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.sb-*.chunk

# Flutter / Dart / Pub
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
.pub-preload-cache/
.pub/
build/
lib/generated_plugin_registrant.dart

# FVM (Flutter Version Management)
# Ignora o SDK local que o FVM baixa, mas rastreia o arquivo de configuração
.fvm/flutter_sdk
!.fvm/fvm_config.json

# Web tools cache
.webpack/
.sass-cache/

# -------------------------------------------------------------------------
# Android Specific
# -------------------------------------------------------------------------
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/key.properties
**/android/**/GeneratedPluginRegistrant.java

# Android Keystores and Tokens (Security Critical)
*.jks
*.keystore
*.p12
*.pem

# -------------------------------------------------------------------------
# iOS Specific
# -------------------------------------------------------------------------
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/.generated/

# CocoaPods (Rastreia o Podfile.lock por segurança, mas ignora os binários)
**/ios/Pods/
**/ios/.symlinks/
**/ios/DerivedData/
**/ios/**/xcuserdata/

# -------------------------------------------------------------------------
# Firebase & Environment Secrets (CRITICAL FOR PUBLIC REPOS)
# -------------------------------------------------------------------------
# Android Firebase config
**/android/app/google-services.json

# iOS Firebase config
**/ios/Runner/GoogleService-Info.plist

# Local environment variables
.env
.env.*
!.env.example

# Firebase CLI cache & logs
.firebase/
firebase-debug.log*
.runtimeconfig.json
.emulator-ui/
firebase-export-*/

# Cloud Functions (Se for usar para o Archive ou Whitelist)
functions/node_modules/
functions/lib/
functions/npm-debug.log*